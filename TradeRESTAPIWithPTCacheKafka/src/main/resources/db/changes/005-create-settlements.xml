<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="005" author="trainer">

        <createTable tableName="settlements">

            <column name="settlement_id" type="BIGSERIAL">
                <constraints primaryKey="true"/>
            </column>

            <column name="trade_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="expected_date" type="DATE">
                <constraints nullable="false"/>
            </column>

            <column name="actual_date" type="DATE"/>

            <column name="custodian_ref" type="VARCHAR(50)">
                <constraints unique="true"/>
            </column>

            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <addForeignKeyConstraint
                baseTableName="settlements"
                baseColumnNames="trade_id"
                constraintName="fk_settlement_trade"
                referencedTableName="trades"
                referencedColumnNames="trade_id"/>

        <sql>
            ALTER TABLE settlements
                ADD CONSTRAINT settlements_status_check
                    CHECK (status IN ('PENDING','UNSETTLED','SETTLED','FAILED'));
        </sql>

    </changeSet>

</databaseChangeLog>